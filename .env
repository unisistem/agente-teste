# URL da base de conhecimento em Markdown (obrigatório)
KB_URL=https://raw.githubusercontent.com/igortce/python-agent-challenge/refs/heads/main/python_agent_knowledge_base.md

# Configuração do LLM (Ollama local)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:1.5b
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=

# Armazenamento de memória por sessão
# Deixar vazio na entrega mínima (memória em processo).
# Pode ser configurado futuramente com Redis, SQLite, etc.
MEMORY_STORE=

# Host e porta da API
HOST=0.0.0.0
PORT=8000
